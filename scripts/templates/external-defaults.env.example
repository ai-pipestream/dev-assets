# Pre-fill defaults for configure-external.sh WITHOUT committing your hostnames.
#
#   cp this file to ~/.pipeline/dev/external-defaults.env  and edit.
#
# configure-external.sh sources it automatically and uses these as the prompt
# defaults (you can still override at the prompt). This file is machine-local —
# keep your real hosts here, not in the repo.
#
# Examples (replace with your own infra):
#DEFAULT_OPENSEARCH_URL=https://opensearch.example.com
#DEFAULT_OPENSEARCH_USER=
#DEFAULT_OPENSEARCH_PASS=
#DEFAULT_REDIS_HOST=redis.example.com
#DEFAULT_REDIS_PORT=6379
#DEFAULT_DJL_URL=http://djl.example.com:8090
#DEFAULT_DOCLING_URL=http://docling.example.com:5001
#DEFAULT_DOCLING_KEY=
#DEFAULT_KAFKA_HOST=kafka.example.com
#DEFAULT_KAFKA_PORT=9094
#DEFAULT_APICURIO_URL=http://apicurio.example.com:8081/apis/registry/v3
